{
  "name": "hoodclaw",
  "version": "0.2.0",
  "private": false,
  "license": "MIT",
  "description": "HoodClaw protocol contracts for operator-routed paid API settlement on Robinhood Chain",
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "deploy:hoodclaw:testnet": "hardhat run scripts/deploy-hoodclaw.js --network robinhoodTestnet",
    "deploy:batch-router:testnet": "hardhat run scripts/deploy-batch-router.js --network robinhoodTestnet",
    "verify:hoodclaw:testnet": "hardhat run scripts/verify-info.js --network robinhoodTestnet",
    "test:settlement:testnet": "hardhat run scripts/test-live-settlement.js --network robinhoodTestnet",
    "test:batch-settlement:testnet": "hardhat run scripts/test-live-batch-settlement.js --network robinhoodTestnet",
    "size": "hardhat size-contracts",
    "lint": "solhint 'contracts/**/*.sol'"
  },
  "dependencies": {},
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "dotenv": "^16.6.1",
    "hardhat": "^2.26.5"
  }
}
